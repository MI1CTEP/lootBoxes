    \u0418\u041B\u0418 <color=#F9C04B>\u041B\u0415\u0413\u0415\u041D\u0414\u0410\u0420\u041D\u041E\u0419</color>
    \u041A\u0410\u0420\u0422\u041E\u0427\u041A\u0418 \u0412\u042B\u0421\u041E\u041A\u0410\u042F"
